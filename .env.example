AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-5-mini
OPENROUTER_API_KEY=sk-or-v1-...
EXA_API_KEY=something

# Optional local Browser Use overrides
# BROWSER_USE_LOCAL_MODEL=something
# BROWSER_USE_DEFAULT_MODEL=something
# BROWSER_USE_EXTRACT_MODEL=something
# BROWSER_USE_HEADLESS=true
# BROWSER_USE_USER_DATA_DIR=.browser-use-profile

# Production safety limits
# SCHOOLYANK_MAX_CONCURRENCY=32
# SCHOOLYANK_MAX_SCRAPE_ATTEMPTS=2
# SCHOOLYANK_MAX_RATE_LIMIT_ATTEMPTS=2
# SCHOOLYANK_MIN_BROWSER_START_TIMEOUT_SECONDS=120
# SCHOOLYANK_BATCH_SLACK_THREADS=false

# Production Docker defaults
# LOG_FILE=/app/logs/schoolyank.log
# STATUS_CSV_PATH=/app/output/status.csv
# SCHOOLYANK_INPUT_CSV=/app/input/schools_with_staff_urls.csv

# Optional Slack integration
SLACK_BOT_TOKEN=something
SLACK_CHANNEL_ID=something
SLACK_ALERT_USER=something

# Optional: when set, every school upserts its teachers into
# public.extracted_teachers immediately after the per-school CSV is written.
# docker-compose.yml overrides this to the local `postgres` container.
DATABASE_URL=postgres://schoolyank:schoolyank@localhost:5432/schoolyank
# Set true in production if the run should fail instead of falling back to CSV-only mode.
REQUIRE_DATABASE=true
