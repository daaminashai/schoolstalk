# Optional: when set, every school upserts its teachers into
# public.extracted_teachers immediately after the per-school CSV is written.
# Multiple workers (concurrent `bun index.ts` runs against the same
# schools_with_staff_urls.csv on the same machine OR different machines
# pointing at the same DB) coordinate via per-school file locks AND
# ON CONFLICT DO UPDATE on the table — safe to run in parallel.
DATABASE_URL=postgres://user:pass@b.selfhosted.hackclub.com:3492/postgres
